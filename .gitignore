# External benchmark cache (CRUST-bench dataset + results). Never committed —
# the dataset is GPL-3.0 licensed and fetched at run time, not vendored.
/.crust-bench-cache/
crust-bench-cache/

# Rust build artifacts (from any crates built during benchmark scoring)
target/
Cargo.lock

# Script scratch (SQLite two-mode emits, mirror staging) — always under ./temp/,
# trap-cleaned on completion; never committed.
/temp/

# Logs
*.log

# OS cruft
.DS_Store

# Python bytecode (report generator)
__pycache__/
